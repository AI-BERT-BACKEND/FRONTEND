# AI.BERT Frontend — Variables de Entorno
# Copia este archivo como .env.development y ajusta los valores

# === API Gateway Principal ===
# URL base del API Gateway (incluye /api si corresponde)
# Ejemplo: http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api

# === Planning / Motor IA ===
# URL del servicio de planificación (opcional, fallback a VITE_API_URL)
VITE_PLANNING_API_URL=http://localhost:1504
